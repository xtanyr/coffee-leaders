# Frontend dev server (Create React App reads these automatically)
HOST=0.0.0.0
PORT=3100

# Optional: public URL when users open the app by hostname or IP (asset URLs, hot reload)
# PUBLIC_URL=http://localhost:3100

# Backend port (used by setupProxy.js when REACT_APP_API_PROXY is unset)
BACKEND_PORT=3011

# Where setupProxy.js forwards /api in development (overrides BACKEND_PORT)
# REACT_APP_API_PROXY=http://127.0.0.1:3011

# Only needed for production static builds without a reverse proxy on /api
# REACT_APP_API_URL=/api

# PM2 / production: comma-separated origins allowed to call the API from the browser
# CORS_ORIGIN=http://localhost:3100,https://your-domain.example
